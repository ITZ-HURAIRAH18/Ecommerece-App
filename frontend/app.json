{
  "expo": {
    "name": "ShopEase",
    "slug": "shopease",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "shopease",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#FF6B00"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shopease.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FF6B00"
      },
      "package": "com.shopease.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ]
  }
}
